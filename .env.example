# --- Supabase (same project clinic-tracker uses) ---
SUPABASE_URL=https://pdlhcgdjrqzjanonevqx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=paste_service_role_key_here
# Use the SERVICE ROLE key (not the anon key) because this backend runs
# server-side only and needs to read/write tasks and approvals directly.
# NEVER expose this key in any browser-facing code.

# --- Manager account (sends the "please update" emails) ---
MANAGER_NAME=Manager Name
MANAGER_EMAIL=manager@newderma1.com
MANAGER_SMTP_HOST=mail.newderma1.com
MANAGER_SMTP_PORT=587
MANAGER_SMTP_USER=manager@newderma1.com
MANAGER_SMTP_PASS=paste_mailbox_password_here

# --- Public URL where the approval page is reachable ---
# e.g. https://approve.newderma1.com or wherever you host public/approve.html
APPROVAL_BASE_URL=https://approve.newderma1.com

# --- How often to re-contact an employee with open tasks (days) ---
FOLLOWUP_INTERVAL_DAYS=4

# --- How long an approval link stays valid (hours) ---
APPROVAL_LINK_EXPIRY_HOURS=72

# --- Server port ---
PORT=3000

# --- Per-employee SMTP credentials ---
# Each employee needs their own mailbox password so replies send as THEM.
# Format: EMPLOYEE_SMTP_<EMPLOYEE_ID>=host|port|user|pass
# The <EMPLOYEE_ID> must match the `smtp_key` column you set for that
# employee row in Supabase (see sql/schema.sql). Example for Israa:
EMPLOYEE_SMTP_ISRAA=mail.newderma1.com|587|israa@newderma1.com|paste_password_here
EMPLOYEE_SMTP_LEGAL=mail.newderma1.com|587|legal@newderma1.com|paste_password_here
# Add one line per employee.
